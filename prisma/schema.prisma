// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// never use the migrate command. always do the db push 
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FARMER
  BEGINNER
  GARDENER
  STUDENT
  OTHER
}

enum CropType {
  MAIZE
  TOMATO
  CASSAVA
  PLANTAIN
  PEPPER
  COCOA
  // Add more crops here in future
}

enum CropStatus {
  HEALTHY
  MONITORING
  AT_RISK
  HARVEST_READY
}

enum NotificationType {
  DAILY_SUMMARY
  HIGH_RISK
  CROP_SPECIFIC
  FAVORABLE_CONDITION
  GENERAL_ADVICE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  role            UserRole @default(OTHER)
  phoneNumber     String
  isOnboarded     Boolean  @default(false)
  isEmailVerified Boolean  @default(false)
  language        String   @default("en") // For Twi support later

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  profile            Profile?
  detections         Detection[]
  // posts         Post[]     // Will be added later for community
  userPreferredCrops UserPreferredCrop[]
  weatherRequests    WeatherRequest[]
  notifications      Notification[]

  cachedDiagnoses CachedDiagnosis[]

  @@index([email])
  @@index([phoneNumber])
  @@map("users")
}

// Profile model (one-to-one with User)
model Profile {
  id             String     @id @default(cuid())
  userId         String     @unique
  fullName       String
  avatarUrl      String?
  location       Json? // { latitude, longitude, address, accuracy? } - Auto-detected from frontend GPS
  preferredCrops CropType[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// For future scalability (User <-> CropType)
model UserPreferredCrop {
  userId              String
  cropType            CropType
  // Custom name for ownership feeling (e.g., "My Backyard Maize")
  customName          String?
  plantingDate        DateTime?
  expectedHarvestDate DateTime?
  farmSize            Decimal?
  farmSizeUnit        String?    @default("acres")
  notes               String?
  status              CropStatus @default(HEALTHY)
  // For easy sorting of recently active crops
  lastActivityDate    DateTime?  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, cropType])
  @@map("user_preferred_crops")
}

model Detection {
  id                String   @id @default(cuid())
  imageUrl          String?
  cropType          CropType
  rawResponse       Json // Store full AI response for debugging/auditing
  diseaseName       String
  confidence        Float    @default(0.0)
  possibleDiseases  Json? // Array of possible diseases with scores
  symptoms          String?
  causes            String?
  organicTreatments String?
  chemicalOptions   String?
  prevention        String?
  localNotes        String? // Ghana/Twi specific recommendations
  aiProvider        String?  @default("gemini")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?

  cachedDiagnosisId String?
  cachedDiagnosis   CachedDiagnosis? @relation(fields: [cachedDiagnosisId], references: [id])

  @@index([cropType])
  @@index([createdAt])
  @@index([userId])
  @@map("detections")
}

model CachedDiagnosis {
  id                  String   @id @default(cuid())
  imageHash           String
  cropType            CropType
  language            String   @default("en")
  result              Json // Full structured diagnosis result
  expiresAt           DateTime
  imagePerceptualHash String?
  diseaseName         String?
  confidence          Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  userId     String?
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  detections Detection[]

  @@unique([imageHash, language])
  @@index([imageHash])
  @@index([cropType, language])
  @@index([expiresAt])
  @@index([diseaseName, cropType, language])
  @@index([imagePerceptualHash])
  @@map("cached_diagnoses")
}

model WeatherRequest {
  id          String  @id @default(cuid())
  userId      String?
  latitude    Float
  longitude   Float
  cropType    String? // Optional specific crop being checked
  rawData     Json // Full Open-Meteo response
  riskSummary Json? // Computed disease risk insights

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("weather_requests")
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  message    String
  priority   Priority         @default(MEDIUM)
  isRead     Boolean          @default(false)
  expiresAt  DateTime? //  For auto-cleanup of old alerts
  actionLink String? //  e.g. "/weather" or deep link
  metadata   Json? // Extra context (weather, crops, etc.)

  sentAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
  @@index([priority])
  @@map("notifications")
}
